# ──────────────────────────────────────────────
# VISIONC 웹사이트 환경변수 예시
# 이 파일을 복사하여 .env.local 을 만들고 값을 채우세요.
# .env.local 은 절대 git에 커밋하지 마세요.
# ──────────────────────────────────────────────

# Telegram 봇 (신청 알림 + 보고서 승인)
# BotFather에서 발급: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCDefghIJKLmnopQRSTuvwxYZ

# Telegram 수신 Chat ID (봇을 채널/그룹에 추가 후 확인)
TELEGRAM_CHAT_ID=123456789

# Telegram 웹훅 보안 시크릿 (강력 권장)
# setWebhook() 호출 시 secret_token 파라미터에 동일한 값을 사용하세요.
# 미설정 시 프로덕션에서 모든 웹훅 요청이 거부됩니다.
# 예: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your_random_secret_token_here

# Upstash Redis (보고서 승인 대기 데이터 임시 저장)
# Upstash 콘솔 → Database → REST API 탭에서 확인
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Gmail (고객에게 PDF 리포트 이메일 발송)
# 앱 비밀번호: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# 사이트 공개 URL (선택 — 기본값: https://www.visionc.co.kr)
# NEXT_PUBLIC_BASE_URL=https://www.visionc.co.kr

# ── 관찰가능성 (VISA-4) ───────────────────────
# 로그 레벨: debug | info | warn | error (기본: info)
# LOG_LEVEL=info

# Sentry 에러 트래킹 (선택 — 설정 시 자동으로 에러 전송)
# 1. npm install @sentry/nextjs
# 2. Sentry 프로젝트 DSN 붙여넣기
# SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0

# 앱 버전 (선택 — /api/health 응답 및 Sentry 릴리스 태그에 사용)
# NEXT_PUBLIC_APP_VERSION=0.1.0
